# Copy to .env and edit as needed.
# Docker Compose reads .env automatically.

# Any Ollama vision model: llava, llava-llama3, llama3.2-vision, moondream
OLLAMA_MODEL=llava

# Server
PORT=8080
MAX_UPLOAD_MB=50

# Uncomment to rate-limit to 5 images/hour/IP.
# RATE_LIMIT_IMAGES=1

# Set if what-pic is behind a reverse proxy (nginx, Caddy, Traefik…)
# so X-Forwarded-For is trusted for rate limiting.
# TRUST_PROXY=1
